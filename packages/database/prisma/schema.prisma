// This is your Prisma schema file
// Vantage — Website Intelligence & Outreach Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProspectStatus {
  NEW
  ENRICHING
  ENRICHED
  AUDITING
  AUDITED
  REPORT_GENERATING
  REPORT_READY
  OUTREACH_QUEUED
  OUTREACH_SENT
  ENGAGED
  CONVERTED
  UNSUBSCRIBED
  SUPPRESSED
  ARCHIVED
}

enum OutreachState {
  PENDING
  APPROVED
  INITIAL_QUEUED
  INITIAL_SENT
  FOLLOWUP_1_QUEUED
  FOLLOWUP_1_SENT
  FOLLOWUP_2_QUEUED
  FOLLOWUP_2_SENT
  FOLLOWUP_3_QUEUED
  FOLLOWUP_3_SENT
  FOLLOWUP_4_QUEUED
  FOLLOWUP_4_SENT
  FOLLOWUP_5_QUEUED
  FOLLOWUP_5_SENT
  COMPLETED
  REPLIED
  OPTED_OUT
  BOUNCED
  SUPPRESSED
}

enum EmailEventType {
  sent
  opened
  clicked
  replied
  bounced
  complained
  unsubscribed
}

enum RecommendationPriority {
  P0
  P1
  P2
}

enum SuppressionType {
  EMAIL
  DOMAIN
}

enum WorkflowRunStatus {
  running
  completed
  failed
}

// ─── Core entities ────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  clerkOrgId  String   @unique @db.VarChar(191)
  name        String   @db.VarChar(191)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  brandConfig  BrandConfig?
  prospects    Prospect[]
  campaigns    Campaign[]
  suppressions SuppressionEntry[]
  dailyLimits  DailyEmailLimit[]
  workflowRuns WorkflowRun[]

  @@map("organizations")
}

model User {
  id           String   @id @default(cuid())
  clerkUserId  String   @unique @db.VarChar(191)
  orgId        String
  email        String   @db.VarChar(191)
  name         String?  @db.VarChar(191)
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@map("users")
}

model BrandConfig {
  id              String  @id @default(cuid())
  orgId           String  @unique
  companyName     String  @default("TexMG") @db.VarChar(191)
  senderName      String  @default("Scott") @db.VarChar(191)
  senderEmail     String  @default("scott@texmg.com") @db.VarChar(191)
  bookingUrl      String? @db.Text
  logoR2Key       String? @db.VarChar(191)
  logoUrl         String? @db.Text
  primaryColor    String  @default("#1a1a2e") @db.VarChar(20)
  accentColor     String  @default("#3b82f6") @db.VarChar(20)
  companyAddress  String? @db.VarChar(500)
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])

  @@map("brand_configs")
}

// ─── Prospect pipeline ────────────────────────────────────────────────────────

model Prospect {
  id           String          @id @default(cuid())
  orgId        String
  domain       String          @db.VarChar(191)
  companyName  String?         @db.VarChar(191)
  industry     String?         @db.VarChar(191)
  city         String?         @db.VarChar(191)
  state        String?         @db.VarChar(100)
  website      String?         @db.VarChar(191)
  status       ProspectStatus  @default(NEW)
  icpScore     Int?
  notes        String?         @db.Text
  sourceType   String?         @db.VarChar(50)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  organization  Organization    @relation(fields: [orgId], references: [id])
  contacts      Contact[]
  audits        WebsiteAudit[]
  reports       ProspectReport[]
  briefs        InternalBrief[]
  painPoints    PainPointAnalysis[]
  threads       OutreachThread[]
  workflowRuns  WorkflowRun[]

  @@unique([orgId, domain])
  @@map("prospects")
}

model Contact {
  id             String   @id @default(cuid())
  prospectId     String
  firstName      String?  @db.VarChar(191)
  lastName       String?  @db.VarChar(191)
  email          String?  @db.VarChar(191)
  title          String?  @db.VarChar(191)
  linkedinUrl    String?  @db.Text
  phone          String?  @db.VarChar(50)
  isPrimary      Boolean  @default(false)
  emailVerified  Boolean  @default(false)
  emailSource    String?  @db.VarChar(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  prospect  Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  emails    Email[]

  @@map("contacts")
}

// ─── Evaluation (CORE) ────────────────────────────────────────────────────────

model WebsiteAudit {
  id            String   @id @default(cuid())
  prospectId    String
  triggeredBy   String?  @db.VarChar(191)
  domain        String   @db.VarChar(191)
  crawlDataKey  String?  @db.VarChar(191)
  screenshotKey String?  @db.VarChar(191)
  overallScore  Int?
  status        String   @default("pending") @db.VarChar(50)
  errorMessage  String?  @db.Text
  crawledAt     DateTime?
  evaluatedAt   DateTime?
  createdAt     DateTime @default(now())

  prospect        Prospect              @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  dimensionScores AuditDimensionScore[]
  recommendations AuditRecommendation[]
  reports         ProspectReport[]

  @@map("website_audits")
}

model AuditDimensionScore {
  id            String   @id @default(cuid())
  auditId       String
  category      String   @db.VarChar(50)
  dimension     String   @db.VarChar(100)
  score         Int
  wins          Json     @default("[]")
  criticalFixes Json     @default("[]")
  notes         String?  @db.Text

  audit WebsiteAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, dimension])
  @@map("audit_dimension_scores")
}

model AuditRecommendation {
  id          String                 @id @default(cuid())
  auditId     String
  priority    RecommendationPriority
  title       String                 @db.VarChar(191)
  description String                 @db.Text
  effort      String                 @db.VarChar(20)
  impact      String                 @db.VarChar(20)
  category    String                 @db.VarChar(50)

  audit WebsiteAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@map("audit_recommendations")
}

// ─── Reports (CORE) ───────────────────────────────────────────────────────────

model ProspectReport {
  id              String   @id @default(cuid())
  prospectId      String
  auditId         String
  publicToken     String   @unique @default(cuid()) @db.VarChar(191)
  pdfKey          String?  @db.VarChar(191)
  pdfUrl          String?  @db.Text
  markdownContent String?  @db.MediumText
  jsonContent     Json?
  viewCount       Int      @default(0)
  status          String   @default("generating") @db.VarChar(50)
  errorMessage    String?  @db.Text
  generatedAt     DateTime?
  createdAt       DateTime @default(now())

  prospect Prospect     @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  audit    WebsiteAudit @relation(fields: [auditId], references: [id])

  @@map("prospect_reports")
}

// ─── Intelligence ────────────────────────────────────────────────────���────────

model InternalBrief {
  id               String   @id @default(cuid())
  prospectId       String
  auditId          String?
  markdownContent  String   @db.MediumText
  appointmentAngle String?  @db.Text
  createdAt        DateTime @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@map("internal_briefs")
}

model PainPointAnalysis {
  id                String   @id @default(cuid())
  prospectId        String
  auditId           String?
  primaryPainPoint  String?  @db.Text
  outreachAngles    Json     @default("[]")
  valueHooks        Json     @default("[]")
  createdAt         DateTime @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@map("pain_point_analyses")
}

// ─── Outreach ─────────────────────────────────────────────────────────────────

model Campaign {
  id              String   @id @default(cuid())
  orgId           String
  name            String   @db.VarChar(191)
  status          String   @default("active") @db.VarChar(50)
  dailyNewLimit   Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization   @relation(fields: [orgId], references: [id])
  threads      OutreachThread[]

  @@map("campaigns")
}

model OutreachThread {
  id            String        @id @default(cuid())
  prospectId    String
  campaignId    String?       @db.VarChar(191)
  state         OutreachState @default(PENDING)
  currentStep   Int           @default(0)
  nextActionAt  DateTime?
  approvedAt    DateTime?
  approvedBy    String?       @db.VarChar(191)
  pausedAt      DateTime?
  pausedReason  String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  prospect Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id])
  emails   Email[]

  // Note: MySQL treats NULL as distinct in unique indexes, so we use @@index here
  // and enforce the one-thread-per-prospect logic in the application layer.
  @@index([prospectId, campaignId])
  @@map("outreach_threads")
}

model Email {
  id              String   @id @default(cuid())
  threadId        String
  contactId       String
  resendMessageId String?  @unique @db.VarChar(191)
  sequenceIndex   Int
  subject         String   @db.VarChar(500)
  htmlBody        String   @db.LongText
  textBody        String?  @db.MediumText
  fromName        String   @db.VarChar(191)
  fromEmail       String   @db.VarChar(191)
  status          String   @default("draft") @db.VarChar(50)
  sentAt          DateTime?
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())

  thread  OutreachThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  contact Contact        @relation(fields: [contactId], references: [id])
  events  EmailEvent[]

  @@map("emails")
}

model EmailEvent {
  id        String         @id @default(cuid())
  emailId   String
  type      EmailEventType
  url       String?        @db.Text
  ipAddress String?        @db.VarChar(45)
  userAgent String?        @db.Text
  data      Json?
  createdAt DateTime       @default(now())

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@map("email_events")
}

// ─── Operations ───────────────────────────────────────────────────────────────

model DailyEmailLimit {
  id              String   @id @default(cuid())
  orgId           String
  date            String   @db.VarChar(10)
  newOutboundSent Int      @default(0)

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, date])
  @@map("daily_email_limits")
}

model SuppressionEntry {
  id        String          @id @default(cuid())
  orgId     String
  type      SuppressionType
  value     String          @db.VarChar(191)
  reason    String?         @db.Text
  createdAt DateTime        @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, type, value])
  @@map("suppression_entries")
}

model WorkflowRun {
  id           String            @id @default(cuid())
  orgId        String
  prospectId   String?
  type         String            @db.VarChar(50)
  status       WorkflowRunStatus @default(running)
  steps        Json              @default("[]")
  startedAt    DateTime          @default(now())
  completedAt  DateTime?
  errorMessage String?           @db.Text

  organization Organization @relation(fields: [orgId], references: [id])
  prospect     Prospect?    @relation(fields: [prospectId], references: [id])

  @@map("workflow_runs")
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  orgId      String
  eventType  String   @db.VarChar(100)
  prospectId String?
  emailId    String?
  data       Json?
  createdAt  DateTime @default(now())

  @@index([orgId, eventType, createdAt])
  @@map("analytics_events")
}

// ─── Attribution ──────────────────────────────────────────────────────────────

model LandingPageVisit {
  id          String   @id @default(cuid())
  orgId       String?
  prospectId  String?
  contactId   String?
  emailId     String?
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text
  referrer    String?  @db.Text
  utmSource   String?  @db.VarChar(100)
  utmMedium   String?  @db.VarChar(100)
  utmCampaign String?  @db.VarChar(100)
  utmContent  String?  @db.VarChar(191)
  createdAt   DateTime @default(now())

  @@index([orgId, emailId])
  @@index([orgId, prospectId])
  @@map("landing_page_visits")
}

// ─── ICP Profiles ─────────────────────────────────────────────────────────────

model IcpProfile {
  id           String   @id @default(cuid())
  orgId        String
  name         String   @db.VarChar(191)
  industries   Json     @default("[]")
  cities       Json     @default("[]")
  states       Json     @default("[]")
  minEmployees Int?
  maxEmployees Int?
  keywords     Json     @default("[]")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId])
  @@map("icp_profiles")
}
